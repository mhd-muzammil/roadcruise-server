# ============================================================================
#  Road Cruise — Server environment template. Copy to .env and fill as needed.
#  The notification module runs with ZERO config (mock providers, JSON store,
#  in-process queue). Everything below is optional and only needed to go live.
# ============================================================================

# Existing
PORT=5000

# ---- Notification engine: master + per-channel feature flags ----
NOTIF_ENABLED=true
NOTIF_EMAIL_ENABLED=true
NOTIF_SMS_ENABLED=true
NOTIF_WHATSAPP_ENABLED=true

# ---- Provider selection (mock = default, no creds required) ----
# email: mock | smtp        sms: mock | twilio        whatsapp: mock | meta
NOTIF_EMAIL_PROVIDER=mock
NOTIF_SMS_PROVIDER=mock
NOTIF_WHATSAPP_PROVIDER=mock

# ---- Substrate (leave unset for zero-infra JSON + in-process queue) ----
# REDIS_URL=redis://localhost:6379          # enables BullMQ queue
# DATABASE_URL=postgres://user:pass@host/db # enables Postgres repository (when implemented)

# ---- Retry / backoff policy ----
NOTIF_MAX_ATTEMPTS=3
NOTIF_BACKOFF_MS=2000
NOTIF_BACKOFF_FACTOR=3
NOTIF_MAX_BACKOFF_MS=60000
NOTIF_BACKOFF_JITTER_MS=500
NOTIF_CONCURRENCY=4

# ---- Branding (used in templates) ----
COMPANY_NAME=Road Cruise
SUPPORT_PHONE=+91 99999 99999
SUPPORT_EMAIL=support@roadcruise.com
COMPANY_URL=https://roadcruise.example
COMPANY_LOGO_URL=

# ---- Admin API protection (REQUIRED in production) ----
# Send this value as the `x-admin-token` header to /api/notifications/*
NOTIF_ADMIN_TOKEN=

# ---- Dead-letter admin alerts ----
NOTIF_DLQ_ALERT_ENABLED=true
NOTIF_DLQ_ALERT_EMAIL=

# ---- SMTP (NOTIF_EMAIL_PROVIDER=smtp) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@roadcruise.com

# ---- Twilio (NOTIF_SMS_PROVIDER=twilio) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# ---- Meta WhatsApp Cloud API (NOTIF_WHATSAPP_PROVIDER=meta) ----
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_API_VERSION=v21.0

# ============================================================================
#  PAYMENT MODULE (Razorpay). Runs with the MOCK gateway by default — no keys
#  needed. Set PAYMENT_PROVIDER=razorpay + the RAZORPAY_* keys to go live.
# ============================================================================
PAYMENTS_ENABLED=true
PAYMENT_WEBHOOK_ENABLED=true
PAYMENT_PROVIDER=mock            # mock | razorpay
PAYMENT_CURRENCY=INR
PAYMENT_TAX_PERCENT=0
PAYMENT_ORDER_EXPIRY_MIN=30
PAYMENT_MAX_ATTEMPTS=3
PAYMENT_BACKOFF_MS=1000

# Mock gateway signing secret (dev/test only; deterministic signatures).
PAYMENT_MOCK_SECRET=mock_secret_key

# Razorpay credentials (required only when PAYMENT_PROVIDER=razorpay).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Admin API token: reuses NOTIF_ADMIN_TOKEN; PAYMENT_ADMIN_TOKEN overrides.
PAYMENT_ADMIN_TOKEN=

# ============================================================================
#  GOOGLE OAUTH 2.0 (additive). Runs in MOCK mode with no credentials so the
#  flow + tests work offline. Set GOOGLE_CLIENT_ID to activate real Google
#  ID-token verification (requires `npm i google-auth-library`).
# ============================================================================
OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Additive session token (JWT-like HS256). REQUIRED in production.
JWT_SECRET=
AUTH_TOKEN_TTL_SEC=604800

# Mock Google verifier secret (dev/test only).
OAUTH_MOCK_SECRET=oauth_mock_secret

# Auto-link a Google login to an existing local account when Google asserts the
# email is verified (prevents duplicate accounts). Set false to require manual linking.
OAUTH_AUTOLINK=true
OAUTH_NONCE_TTL_SEC=600

# NOTE: the frontend "Continue with Google" button fetches the PUBLIC client id
# at runtime from GET /api/auth/google/config (single source of truth = server
# GOOGLE_CLIENT_ID above), so no separate VITE_GOOGLE_CLIENT_ID is required.
#
# GOOGLE_CLIENT_SECRET / GOOGLE_CALLBACK_URL below are reserved for a future
# server-side authorization-code flow; the current ID-token flow does not use them.

# ============================================================================
#  AUTH HARDENING (passwords, JWT access/refresh, lockout, RBAC, recovery)
# ============================================================================
# Feature flags
AUTH_ENABLED=true
GOOGLE_AUTH_ENABLED=true
EMAIL_VERIFICATION_ENABLED=true
PASSWORD_RESET_ENABLED=true
JWT_ENABLED=true
REFRESH_TOKEN_ENABLED=true

# Password hashing: scrypt (default, zero-dep) | argon2 | bcrypt (npm i to enable)
AUTH_PASSWORD_ALGO=scrypt
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# JWT access / refresh TTLs (seconds)
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000

# Account lockout (brute-force)
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MS=900000
AUTH_ATTEMPT_WINDOW_MS=900000

# Per-IP rate limiting
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX_LOGIN=10
AUTH_RATE_MAX_SENSITIVE=5

# Reset / verification token TTLs (seconds) + link base URL
RESET_TOKEN_TTL_SEC=1800
VERIFY_TOKEN_TTL_SEC=86400
APP_BASE_URL=http://localhost:5173
